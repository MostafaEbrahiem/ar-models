    "logs": "firebase functions:log",
    "init-tw": "tailwindcss init",
    "build-tw": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch"
  },
  "engines": {
    "node": "24"
  },
  "main": "index.js",
  "dependencies": {
    "cors": "^2.8.6",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "replicate": "^1.4.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.4.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  },
  "private": true
}
